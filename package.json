{
  "name": "treaty",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "vite": "vite",
    "vite:build": "vite build",
    "watch": "ng build --watch --configuration development",
    "server": "bun run server.ts",
    "server:watch": "bun --watch server.ts",
    "dev": "concurrently \"npm run watch\" \"npm run server:watch\"",
    "dev:vite": "concurrently \"bun run vite --host --port 5173 --strictPort --open\" \"bun run server:watch\"",
    "precommit:verify": "bun run build && bun run vite:build",
    "prod": "bun run build && bun run server",
    "prepare": "husky"
  },
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/platform-server": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@angular/ssr": "^20.3.22",
    "@dotenvx/dotenvx": "^1.60.1",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^0.8.1",
    "@elysiajs/static": "^1.4.7",
    "elysia": "^0.8.16",
    "ngxtension": "^2.0.0",
    "rxjs": "~7.8.0",
    "surrealdb.node": "^0.3.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.0",
    "@angular/build": "^20.3.22",
    "@angular/cli": "^20.3.22",
    "@angular/compiler-cli": "^20.3.18",
    "@happy-dom/global-registrator": "^13.3.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bun": "^1.0.5",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.5"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
