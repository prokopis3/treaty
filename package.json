{
  "name": "treaty",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "tw:build": "tailwindcss -i ./src/tailwind.input.css -o ./src/tailwind.generated.css --minify",
    "tw:watch": "tailwindcss -i ./src/tailwind.input.css -o ./src/tailwind.generated.css --watch",
    "surreal:sql": "bunx surreal sql --endpoint wss://crimson-shadow-06ehlgqoqlrbp6dokk1428etgg.aws-use1.surreal.cloud",
    "surreal:init": "bun run backend/scripts/init-surreal.ts",
    "build": "bun run tw:build && ng build --configuration production",
    "vite": "vite",
    "vite:build": "vite build",
    "watch": "concurrently \"bun run tw:watch\" \"ng build --watch --configuration development\"",
    "server": "bun --watch server.ts",
    "server:watch": "bun --watch server.ts",
    "dev": "dotenvx run -f .env.dev -- concurrently \"bun run watch\" \"bun run server:watch\"",
    "dev:vite": "dotenvx run -f .env.dev -- concurrently \"bun run tw:watch\" \"bun run vite --host --port 5173 --strictPort --open\" \"bun run server:watch\"",
    "build:server": "bun build --target=bun --packages=external --outfile=server.bundle.js server.ts",
    "precommit:verify": "bun run build && bun run vite:build",
    "prepare": "husky",
    "pre-commit": "bun run precommit:verify",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "docker:prod:up": "docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose --env-file .env.production -f docker-compose.prod.yml down",
    "deploy:option-a": "bun run docker:prod:up && bun run cf:deploy",
    "prod": "dotenvx run -f .env.production -- bun run build && dotenvx run -f .env.production -- bun run server"
  },
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/platform-server": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@angular/ssr": "^20.3.22",
    "@dotenvx/dotenvx": "^1.60.1",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^0.8.1",
    "@elysiajs/opentelemetry": "^1.4.11",
    "@elysiajs/server-timing": "^1.4.0",
    "@elysiajs/static": "^1.4.7",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.214.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "consola": "^3.4.2",
    "elysia": "^0.8.16",
    "ngxtension": "^2.0.0",
    "rxjs": "~7.8.0",
    "surrealdb": "^2.0.3",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.0",
    "@angular/build": "^20.3.22",
    "@angular/cli": "^20.3.22",
    "@angular/compiler-cli": "^20.3.18",
    "@happy-dom/global-registrator": "^13.3.8",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bun": "^1.0.5",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.5",
    "wrangler": "^4.80.0"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
