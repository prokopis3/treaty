# Runtime environment
NODE_ENV=production
HOST=localhost
PORT=4201

# Logging
APP_LOG_LEVEL=info
APP_DEBUG_LOGS=false
NO_COLOR=
OTEL_ENABLED_DEV=false
OTEL_ENABLED_PROD=false
SERVER_TIMING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=

# Cloudflare Worker deploy
# Public origin hostname for the reverse-proxy Worker.
CF_ORIGIN_URL=https://origin.example.com
# Optional comma-separated list of Worker secret ENV NAMES to sync via wrangler secret put.
# Example: CF_SECRET_KEYS=API_TOKEN,DB_PASSWORD
CF_SECRET_KEYS=

# CORS
# Comma-separated list of allowed origins. Use * to allow all.
CORS_ORIGIN=
CORS_CREDENTIALS=false

# Cloudflare tunnel token from Zero Trust -> Networks -> Tunnels
CLOUDFLARED_TOKEN=replace-with-your-tunnel-token

# SurrealDB Cloud / remote database
SURREAL_ENDPOINT=
SURREAL_NAMESPACE=
SURREAL_DATABASE=
SURREAL_AUTH_MODE=
SURREAL_USERNAME=
SURREAL_PASSWORD=
SURREAL_ACCESS_TOKEN=
SURREAL_STRICT=false

# Page cache backend: surreal | upstash | memory
APP_PAGE_CACHE_PROVIDER=surreal
APP_PAGE_CACHE_KEY_PREFIX=page-cache:
# 0 means no expiry
APP_PAGE_CACHE_TTL_SECONDS=0
# HTML cache mode: shared-shell (single cache key for CSR shell) | route (one key per route)
APP_HTML_CACHE_MODE=shared-shell
# Route allowlist and prewarm list (used only when APP_HTML_CACHE_MODE=route)
APP_HTML_CACHE_ALLOWLIST=/,/posts,/post/*
APP_HTML_CACHE_PREWARM_ROUTES=/,/posts

# Upstash Redis (required when APP_PAGE_CACHE_PROVIDER=upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
